# ==============================================================================
# PGNServer - Environment Variables Configuration Template (.env.example)
# ==============================================================================

# --- Lingkungan Aplikasi (APP_ENV) ---
# Pilihan: development, staging, production
APP_ENV=development

# --- Konfigurasi Server Gin Backend ---
APP_PORT=8080
GIN_MODE=debug # Pilihan: 'debug' atau 'release'

# --- Kredensial & Koneksi Database (PostgreSQL 17.x) ---
DB_NAME=pgn_db
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://admin:admin@localhost:5432/pgn_db?sslmode=disable

# --- Keamanan & Otentikasi ---
# JWT_SECRET lama untuk kompatibilitas
JWT_SECRET=pgn-rahasia-2026
# JWT Kunci Rahasia Baru
JWT_ACCESS_SECRET=pgn-access-rahasia-2026-super-secret-key-32-chars
JWT_REFRESH_SECRET=pgn-refresh-rahasia-2026-super-secret-key-32-chars

# --- Integrasi Frontend & CORS ---
FRONTEND_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Dokumentasi API (Swagger) ---
SWAGGER_DOCS_URL=/swagger/index.html
