# ==============================================================================
# PGNServer - Environment Variables Configuration Template (.env.example)
# ==============================================================================
# Petunjuk: Salin berkas ini menjadi '.env' dan sesuaikan nilainya untuk development lokal.
# Dilarang keras melakukan commit terhadap berkas '.env' yang berisi kredensial asli!

# --- Kredensial & Koneksi Database (PostgreSQL 17.x) ---
DB_NAME=pgn_db
DB_USER=pengguna_db_contoh
DB_PASSWORD=sandi_db_contoh
DB_HOST=localhost
DB_PORT=5432

# --- Konfigurasi Server Gin Backend ---
APP_PORT=8080
GIN_MODE=debug # Pilihan: 'debug' atau 'release'

# --- Dokumentasi API (Swagger) ---
SWAGGER_DOCS_URL=/swagger/index.html

# --- Keamanan & Otentikasi ---
JWT_SECRET=gunakan-string-acak-dan-sangat-rahasia-minimal-32-karakter-di-sini
