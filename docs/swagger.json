{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/auth/login": {
            "post": {
                "description": "Login menggunakan NIP dan Password untuk mendapatkan JWT",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "User Login",
                "parameters": [
                    {
                        "description": "Credentials",
                        "name": "login",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/pengelola.LoginInput"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    }
                }
            }
        },
        "/media/upload": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengunggah file gambar ke folder penyimpanan",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Media"
                ],
                "summary": "Upload Media",
                "parameters": [
                    {
                        "type": "file",
                        "description": "File gambar",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    }
                }
            }
        },
        "/produk": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengambil semua data produk dari database",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Produk"
                ],
                "summary": "Ambil Semua Produk",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    }
                }
            },
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Menyimpan data produk baru ke database",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Produk"
                ],
                "summary": "Tambah Produk Baru",
                "parameters": [
                    {
                        "description": "Data Produk",
                        "name": "produk",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Produk"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    }
                }
            }
        },
        "/qc-tools/control-chart": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Kalkulasi paralel UCL, LCL, dan Rata-rata menggunakan Goroutine",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "QC-Tools"
                ],
                "summary": "Ambil Data Control Chart",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    }
                }
            }
        },
        "/qc-tools/pareto": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengambil data 80/20 cacat tertinggi menggunakan Goroutine",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "QC-Tools"
                ],
                "summary": "Ambil Data Pareto",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    }
                }
            }
        },
        "/qc/checksheet": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Menyimpan data checksheet (Header \u0026 Detail) serta mencatat log defect secara otomatis",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "QC-Checksheet"
                ],
                "summary": "Simpan Checksheet QC \u0026 Log NG",
                "parameters": [
                    {
                        "description": "Data Checksheet",
                        "name": "checksheet",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/pengelola.ChecksheetInput"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    }
                }
            }
        },
        "/qc/form-checksheet/{produk_id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengambil potensi defect material (via BOM) dan defect proses secara paralel",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "QC-Checksheet"
                ],
                "summary": "Ambil Form Checksheet Dinamis",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID Produk",
                        "name": "produk_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/utilitas.ResponsAPI"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.BillOfMaterial": {
            "type": "object",
            "properties": {
                "material": {
                    "$ref": "#/definitions/model.Material"
                },
                "material_id": {
                    "type": "string"
                },
                "produk_id": {
                    "type": "string"
                },
                "usage_qty": {
                    "type": "number"
                }
            }
        },
        "model.DefectMaster": {
            "type": "object",
            "properties": {
                "dibuat_pada": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "kategori": {
                    "description": "MATERIAL or PROCESS",
                    "type": "string"
                },
                "nama_ng": {
                    "type": "string"
                }
            }
        },
        "model.Material": {
            "type": "object",
            "properties": {
                "dibuat_pada": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "nama_part": {
                    "type": "string"
                },
                "nomor_unik": {
                    "type": "string"
                },
                "potensi_defect": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.DefectMaster"
                    }
                },
                "satuan": {
                    "type": "string"
                },
                "supplier_id": {
                    "type": "string"
                }
            }
        },
        "model.Produk": {
            "type": "object",
            "properties": {
                "assy_name": {
                    "type": "string"
                },
                "bom": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.BillOfMaterial"
                    }
                },
                "customer_id": {
                    "type": "string"
                },
                "dibuat_pada": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "line_id": {
                    "type": "string"
                },
                "model": {
                    "type": "string"
                },
                "nama_part": {
                    "type": "string"
                },
                "nomor_part": {
                    "type": "string"
                },
                "nomor_unik": {
                    "type": "string"
                }
            }
        },
        "pengelola.ChecksheetInput": {
            "type": "object",
            "required": [
                "details",
                "header"
            ],
            "properties": {
                "details": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "parameter_hasil",
                            "proses"
                        ],
                        "properties": {
                            "defects": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "defect_id": {
                                            "type": "string"
                                        },
                                        "jumlah": {
                                            "type": "integer"
                                        }
                                    }
                                }
                            },
                            "keterangan": {
                                "type": "string"
                            },
                            "parameter_hasil": {
                                "type": "object",
                                "additionalProperties": true
                            },
                            "proses": {
                                "description": "PRESS, SEWING, CUTTING",
                                "type": "string"
                            }
                        }
                    }
                },
                "header": {
                    "type": "object",
                    "required": [
                        "line_id",
                        "produk_id",
                        "shift",
                        "user_id"
                    ],
                    "properties": {
                        "line_id": {
                            "type": "string"
                        },
                        "produk_id": {
                            "type": "string"
                        },
                        "shift": {
                            "type": "integer"
                        },
                        "user_id": {
                            "type": "integer"
                        }
                    }
                }
            }
        },
        "pengelola.LoginInput": {
            "type": "object",
            "required": [
                "nip",
                "password"
            ],
            "properties": {
                "nip": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "utilitas.ResponsAPI": {
            "type": "object",
            "properties": {
                "data": {},
                "pesan": {
                    "type": "string"
                },
                "status": {
                    "type": "boolean"
                }
            }
        }
    }
}